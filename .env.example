# ----------------------------------------------------------------------------
# GCP Cost Analyzer — deployment configuration
# Copy to `.env` and edit. `.env` is git-ignored; do not commit real values.
#   cp .env.example .env
# ----------------------------------------------------------------------------

# REQUIRED: project where the Cloud Run service is deployed.
PROJECT_ID=my-app-project

# Project that holds the BigQuery billing export. Defaults to PROJECT_ID if unset.
# Set this when billing data lives in a different project than the app.
BILLING_PROJECT_ID=my-billing-project

# BigQuery dataset that contains the billing export tables (gcp_billing_export_*).
# NOTE: this is whatever you named it in Billing > Billing export (often singular).
BILLING_DATASET=billing_export

# Cloud Run region.
REGION=us-central1

# Cloud Run service name.
SERVICE_NAME=gcp-cost-analyzer-app

# Short name for the dedicated runtime service account (created in PROJECT_ID).
RUNTIME_SA_NAME=cost-analyzer-run

# true  => service is private and protected by Identity-Aware Proxy (recommended)
# false => service is PUBLIC (allow-unauthenticated)
ENABLE_IAP=true

# Comma-separated IAM principals granted dashboard access when IAP is enabled.
# Leave empty and use ./share.sh later. Examples:
#   user:alice@example.com,group:finance@example.com,domain:example.com
IAP_MEMBERS=

# Cloud Run scaling (defaults keep cost near $0 by scaling to zero).
MIN_INSTANCES=0
MAX_INSTANCES=1
